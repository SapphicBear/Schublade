generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique
  password    String
  name        String?
  permissions Permission @default(Normal)
  files       File[]
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model File {
  id      Int      @id @default(autoincrement())
  userId  Int
  created DateTime @default(now())
  type    Type
  url     String?
  name    String
  user    User     @relation(fields: [userId], references: [id])
}

enum Type {
  Text
  Image
  Video
  Audio
  PDF
}

enum Permission {
  Normal
  Member
  Admin
}
